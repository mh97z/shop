<%- include('partials/admin-header') %>

<div class="flex items-center justify-between mb-6">
  <a href="/admin/products/new"
     class="bg-amber-600 hover:bg-amber-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold flex items-center gap-2 shadow-sm transition-colors">
    <i class="fas fa-plus"></i> إضافة منتج جديد
  </a>
</div>

<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
        <tr>
          <th class="px-4 py-3 text-right w-16">الصورة</th>
          <th class="px-4 py-3 text-right">الاسم</th>
          <th class="px-4 py-3 text-right">الفئة</th>
          <th class="px-4 py-3 text-right">السعر</th>
          <th class="px-4 py-3 text-right">الحالة</th>
          <th class="px-4 py-3 text-right">الإجراءات</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% products.forEach(p => { %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-3">
            <img src="<%= p.images[0] || '/img/placeholder.png' %>" alt="" class="w-12 h-12 rounded-lg object-cover bg-gray-50" onerror="this.src='/img/placeholder.png'" />
          </td>
          <td class="px-4 py-3 font-medium text-gray-800 max-w-[200px]">
            <a href="/products/<%= p.slug %>" target="_blank" class="hover:text-amber-600 line-clamp-1"><%= p.name %></a>
          </td>
          <td class="px-4 py-3 text-gray-500"><%= p.category ? p.category.name : '—' %></td>
          <td class="px-4 py-3 font-semibold text-amber-700"><%= p.basePrice.toLocaleString('ar-IQ') %> د.ع</td>
          <td class="px-4 py-3">
            <span class="px-2 py-0.5 rounded-full text-xs <%= p.active ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600' %>">
              <%= p.active ? 'نشط' : 'مخفي' %>
            </span>
          </td>
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
              <a href="/admin/products/<%= p._id %>/edit"
                 class="text-blue-500 hover:text-blue-700 p-1.5 hover:bg-blue-50 rounded-lg transition-colors" title="تعديل">
                <i class="fas fa-edit text-sm"></i>
              </a>
              <form method="POST" action="/admin/products/<%= p._id %>?_method=DELETE">
                <button type="submit" data-confirm="هل أنت متأكد من حذف هذا المنتج؟"
                        class="text-red-400 hover:text-red-600 p-1.5 hover:bg-red-50 rounded-lg transition-colors" title="حذف">
                  <i class="fas fa-trash-alt text-sm"></i>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
        <% if (products.length === 0) { %>
        <tr><td colspan="6" class="text-center py-12 text-gray-400">
          <i class="fas fa-box-open text-4xl block mb-3"></i>
          لا توجد منتجات. <a href="/admin/products/new" class="text-amber-600 hover:underline">أضف أول منتج</a>
        </td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/admin-footer') %>

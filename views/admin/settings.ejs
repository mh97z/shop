<%- include('../partials/admin-header') %>

<div class="max-w-2xl">
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3 mb-4"><%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-xl px-4 py-3 mb-4"><%= success %></div>
  <% } %>

  <form method="POST" action="/admin/settings?_method=PUT" enctype="multipart/form-data" class="space-y-5">
    <input type="hidden" name="_method" value="PUT" />

    <!-- اسم المتجر والشعار -->
    <div class="bg-white rounded-2xl p-5 shadow-sm">
      <h3 class="font-semibold text-gray-700 mb-4">معلومات المتجر</h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1.5">اسم المتجر *</label>
          <input type="text" name="storeName" value="<%= tenant.storeName %>" required
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-pink-400" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1.5">شعار المتجر</label>
          <% if (tenant.logo) { %>
          <img src="<%= tenant.logo %>" class="h-16 w-16 rounded-full object-contain border border-gray-100 mb-2" />
          <% } %>
          <input type="file" name="logo" accept="image/*"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2 text-sm file:mr-3 file:border-0 file:bg-pink-50 file:text-pink-600 file:rounded-lg file:px-3 file:py-1 file:text-xs" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1.5">اللون الرئيسي</label>
            <div class="flex items-center gap-2">
              <input type="color" name="primaryColor" value="<%= tenant.primaryColor || '#EC4899' %>"
                     class="h-10 w-16 border border-gray-200 rounded-xl px-1 cursor-pointer" />
              <span class="text-xs text-gray-400">لون الأزرار والتمييز</span>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1.5">العملة</label>
            <input type="text" name="currency" value="<%= tenant.currency || 'د.ع' %>"
                   class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-pink-400" />
          </div>
        </div>
      </div>
    </div>

    <!-- التواصل الاجتماعي -->
    <div class="bg-white rounded-2xl p-5 shadow-sm">
      <h3 class="font-semibold text-gray-700 mb-4">التواصل الاجتماعي</h3>
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <i class="fab fa-whatsapp text-green-500 w-6 text-center text-lg"></i>
          <input type="text" name="whatsapp" value="<%= tenant.whatsapp || '' %>" placeholder="9647XXXXXXXXX"
                 class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-pink-400" />
        </div>
        <div class="flex items-center gap-3">
          <i class="fab fa-instagram text-pink-500 w-6 text-center text-lg"></i>
          <input type="text" name="instagram" value="<%= tenant.instagram || '' %>" placeholder="https://instagram.com/..."
                 class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-pink-400" />
        </div>
        <div class="flex items-center gap-3">
          <i class="fab fa-tiktok text-gray-700 w-6 text-center text-lg"></i>
          <input type="text" name="tiktok" value="<%= tenant.tiktok || '' %>" placeholder="https://tiktok.com/..."
                 class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-pink-400" />
        </div>
        <div class="flex items-center gap-3">
          <i class="fab fa-telegram text-blue-500 w-6 text-center text-lg"></i>
          <input type="text" name="telegram" value="<%= tenant.telegram || '' %>" placeholder="https://t.me/..."
                 class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-pink-400" />
        </div>
        <div class="flex items-center gap-3">
          <i class="fab fa-facebook text-blue-600 w-6 text-center text-lg"></i>
          <input type="text" name="facebook" value="<%= tenant.facebook || '' %>" placeholder="https://facebook.com/..."
                 class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-pink-400" />
        </div>
      </div>
    </div>

    <button type="submit" class="w-full bg-pink-500 hover:bg-pink-600 text-white font-semibold py-3 rounded-2xl transition-colors">
      <i class="fas fa-save me-2"></i> حفظ الإعدادات
    </button>
  </form>
</div>

<%- include('../partials/admin-footer') %>

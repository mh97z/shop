<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Platform Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-gray-50">
<!-- Nav -->
<nav class="bg-indigo-700 text-white px-6 py-3 flex items-center justify-between">
  <div class="flex items-center gap-3">
    <i class="fas fa-shield-alt text-xl"></i>
    <span class="font-bold text-lg">Platform Admin</span>
  </div>
  <div class="flex items-center gap-4 text-sm">
    <a href="/superadmin" class="hover:text-indigo-200">الرئيسية</a>
    <a href="/superadmin/tenants" class="hover:text-indigo-200 font-bold">المتاجر</a>
    <a href="/superadmin/plans" class="hover:text-indigo-200">الباقات</a>
    <form method="POST" action="/superadmin/logout" class="inline">
      <button class="hover:text-red-300">خروج</button>
    </form>
  </div>
</nav>

<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">المتاجر</h1>
    <button onclick="document.getElementById('newTenantModal').classList.remove('hidden')"
            class="bg-indigo-600 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-indigo-700 transition-colors">
      <i class="fas fa-plus me-1"></i> متجر جديد
    </button>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3 mb-4"><%= error %></div>
  <% } %>

  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
        <tr>
          <th class="px-4 py-3 text-right">المتجر</th>
          <th class="px-4 py-3 text-right">المالك</th>
          <th class="px-4 py-3 text-right">الباقة</th>
          <th class="px-4 py-3 text-right">تنتهي في</th>
          <th class="px-4 py-3 text-right">الحالة</th>
          <th class="px-4 py-3 text-right">إجراءات</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% tenants.forEach(t => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3">
            <div class="font-semibold text-gray-800"><%= t.storeName %></div>
            <div class="text-xs text-gray-400"><%= t.subdomain %></div>
          </td>
          <td class="px-4 py-3 text-gray-600">
            <%= t.ownerName %><br>
            <span class="text-xs text-gray-400"><%= t.ownerEmail %></span>
          </td>
          <td class="px-4 py-3"><span class="text-xs px-2 py-0.5 rounded-full bg-indigo-100 text-indigo-700"><%= t.plan?.nameAr || 'بدون' %></span></td>
          <td class="px-4 py-3 text-xs text-gray-500"><%= t.planExpiry ? new Date(t.planExpiry).toLocaleDateString('ar') : '-' %></td>
          <td class="px-4 py-3"><span class="text-xs px-2 py-0.5 rounded-full <%= t.active ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600' %>"><%= t.active ? 'نشط' : 'موقوف' %></span></td>
          <td class="px-4 py-3">
            <button onclick="openEditModal('<%= t._id %>', '<%= t.plan?._id || '' %>', '<%= t.planExpiry ? new Date(t.planExpiry).toISOString().split('T')[0] : '' %>', '<%= t.active %>')"
                    class="text-xs text-indigo-600 hover:underline">تعديل</button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal: متجر جديد -->
<div id="newTenantModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl w-full max-w-lg max-h-screen overflow-y-auto p-6">
    <div class="flex justify-between items-center mb-5">
      <h2 class="text-lg font-bold">إنشاء متجر جديد</h2>
      <button onclick="document.getElementById('newTenantModal').classList.add('hidden')"><i class="fas fa-times text-gray-400"></i></button>
    </div>
    <form method="POST" action="/superadmin/tenants" class="space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">اسم المتجر *</label>
          <input type="text" name="storeName" required class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-indigo-400" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Subdomain *</label>
          <input type="text" name="subdomain" required placeholder="mystore" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-indigo-400" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">اسم المالك *</label>
          <input type="text" name="ownerName" required class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-indigo-400" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">البريد الإلكتروني *</label>
          <input type="email" name="ownerEmail" required class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-indigo-400" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">اسم مستخدم الإدارة *</label>
          <input type="text" name="adminUsername" required class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-indigo-400" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">كلمة مرور الإدارة *</label>
          <input type="text" name="adminPassword" required class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-indigo-400" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">الباقة</label>
          <select name="planId" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-indigo-400">
            <option value="">-- بدون باقة --</option>
            <% plans.forEach(p => { %>
            <option value="<%= p._id %>"><%= p.nameAr %> ($<%= p.price %>/شهر)</option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">أيام تجريبية</label>
          <input type="number" name="trialDays" value="14" min="0" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-indigo-400" />
        </div>
      </div>
      <button type="submit" class="w-full bg-indigo-600 text-white font-semibold py-2.5 rounded-xl hover:bg-indigo-700 transition-colors mt-2">
        إنشاء المتجر
      </button>
    </form>
  </div>
</div>

<!-- Modal: تعديل الاشتراك -->
<div id="editModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl w-full max-w-sm p-6">
    <div class="flex justify-between items-center mb-5">
      <h2 class="text-lg font-bold">تعديل الاشتراك</h2>
      <button onclick="document.getElementById('editModal').classList.add('hidden')"><i class="fas fa-times text-gray-400"></i></button>
    </div>
    <form id="editForm" method="POST" class="space-y-3">
      <input type="hidden" name="_method" value="PUT" />
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">الباقة</label>
        <select name="planId" id="editPlanId" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none">
          <option value="">-- بدون باقة --</option>
          <% plans.forEach(p => { %>
          <option value="<%= p._id %>"><%= p.nameAr %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">تاريخ انتهاء الاشتراك</label>
        <input type="date" name="planExpiry" id="editExpiry" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none" />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">الحالة</label>
        <select name="active" id="editActive" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none">
          <option value="true">نشط</option>
          <option value="false">موقوف</option>
        </select>
      </div>
      <button type="submit" class="w-full bg-indigo-600 text-white font-semibold py-2.5 rounded-xl hover:bg-indigo-700 transition-colors">حفظ</button>
    </form>
  </div>
</div>

<script>
function openEditModal(id, planId, expiry, active) {
  document.getElementById('editForm').action = '/superadmin/tenants/' + id;
  document.getElementById('editPlanId').value = planId;
  document.getElementById('editExpiry').value = expiry;
  document.getElementById('editActive').value = active;
  document.getElementById('editModal').classList.remove('hidden');
}
</script>
</body>
</html>

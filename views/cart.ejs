<%- include('partials/header') %>

<script>window._currency = '<%= currency %>';</script>

<div class="max-w-lg mx-auto px-4 py-6 min-h-screen" dir="rtl">

  <h1 class="text-lg font-bold text-gray-900 mb-5">سلة التسوق</h1>

  <% if (!cart || cart.items.length === 0) { %>
    <div class="flex flex-col items-center justify-center py-20 text-center">
      <div class="w-20 h-20 rounded-full bg-pink-50 flex items-center justify-center mb-4">
        <i class="fas fa-shopping-cart text-3xl text-pink-300"></i>
      </div>
      <p class="text-gray-500 mb-6">سلتك فارغة حتى الآن</p>
      <a href="/products" class="bg-pink-500 hover:bg-pink-600 text-white font-bold px-8 py-3 rounded-full transition">
        تصفح المنتجات
      </a>
    </div>
  <% } else { %>
    <div class="space-y-3 mb-6">
      <% cart.items.forEach((item, idx) => { %>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 flex gap-3 p-3">
          <a href="/products/<%= item.product.slug %>" class="flex-none">
            <img src="<%= item.product.images?.[0] || '/img/placeholder.png' %>"
                 alt="<%= item.product.name %>" loading="lazy"
                 onerror="this.src='/img/placeholder.png'"
                 class="w-20 h-20 rounded-xl object-cover">
          </a>
          <div class="flex-1 min-w-0">
            <a href="/products/<%= item.product.slug %>">
              <p class="text-sm font-semibold text-gray-800 line-clamp-2 leading-tight mb-1"><%= item.product.name %></p>
            </a>
            <% if (item.size) { %><span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full"><%= item.size %></span><% } %>
            <p class="text-pink-500 font-bold text-sm mt-1.5">
              <%= (item.price * item.qty).toLocaleString('ar-IQ') %> <%= currency %>
            </p>
            <div class="flex items-center gap-2 mt-2">
              <form action="/cart/update" method="POST" class="flex items-center gap-1.5">
                <input type="hidden" name="index" value="<%= idx %>">
                <button type="submit" name="qty" value="<%= item.qty - 1 %>"
                  class="w-7 h-7 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 hover:bg-gray-100">
                  <i class="fas fa-minus text-xs"></i>
                </button>
                <span class="w-6 text-center text-sm font-bold text-gray-800"><%= item.qty %></span>
                <button type="submit" name="qty" value="<%= item.qty + 1 %>"
                  class="w-7 h-7 rounded-full bg-pink-50 border border-pink-200 flex items-center justify-center text-pink-500 hover:bg-pink-100">
                  <i class="fas fa-plus text-xs"></i>
                </button>
              </form>
              <form action="/cart/remove" method="POST" class="mr-auto">
                <input type="hidden" name="index" value="<%= idx %>">
                <button type="submit" class="text-gray-300 hover:text-red-400 transition">
                  <i class="fas fa-trash-alt text-sm"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 mb-5">
      <div class="flex justify-between items-center text-sm text-gray-600 mb-2">
        <span>عدد المنتجات</span>
        <span class="font-semibold"><%= cart.items.reduce((s,i)=>s+i.qty,0) %> قطعة</span>
      </div>
      <div class="flex justify-between items-center text-sm text-gray-600 mb-3">
        <span>التوصيل</span>
        <span class="text-green-600 font-semibold">مجاني</span>
      </div>
      <div class="flex justify-between items-center border-t pt-3">
        <span class="font-bold text-gray-800">الإجمالي</span>
        <span class="font-bold text-pink-500 text-lg">
          <%= cart.items.reduce((s,i)=>s+i.price*i.qty,0).toLocaleString('ar-IQ') %> <%= currency %>
        </span>
      </div>
    </div>
    <a href="/checkout"
       class="block w-full bg-pink-500 hover:bg-pink-600 text-white text-center font-bold py-4 rounded-2xl transition text-base shadow-md">
      المتابعة للطلب <i class="fas fa-arrow-left mr-2"></i>
    </a>
    <form action="/cart/clear" method="POST" class="mt-3 text-center">
      <button type="submit" class="text-xs text-gray-400 hover:text-red-400 transition"
        onclick="return confirm('هل تريد مسح السلة؟')">مسح السلة</button>
    </form>
  <% } %>

</div>

<div id="toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-sm px-5 py-2.5 rounded-full shadow-xl z-50 transition-opacity"></div>

<%- include('partials/footer') %>

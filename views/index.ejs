<%- include('partials/header') %>

<!-- ─── Hero Banner / Slider ─────────────────────────────────────────────── -->
<% if (tenant && tenant.banners && tenant.banners.filter(b => b.active).length > 0) { %>
<section class="relative overflow-hidden" id="bannerSection">
  <div class="banner-slider" id="bannerSlider">
    <% tenant.banners.filter(b => b.active).forEach((banner, i) => { %>
    <div class="banner-slide <%= i === 0 ? 'active' : '' %>">
      <% if (banner.link) { %><a href="<%= banner.link %>"><% } %>
      <img src="<%= banner.image %>" alt="<%= banner.title || storeName %>"
           class="w-full h-48 sm:h-64 object-cover"
           loading="<%= i === 0 ? 'eager' : 'lazy' %>" />
      <% if (banner.title) { %>
      <div class="banner-overlay">
        <h2 class="text-xl font-black leading-tight"><%= banner.title %></h2>
        <% if (banner.subtitle) { %><p class="text-sm mt-1 opacity-90"><%= banner.subtitle %></p><% } %>
      </div>
      <% } %>
      <% if (banner.link) { %></a><% } %>
    </div>
    <% }) %>
  </div>
  <% if (tenant.banners.filter(b => b.active).length > 1) { %>
  <!-- Dots -->
  <div class="flex justify-center gap-1.5 py-2 absolute bottom-2 w-full">
    <% tenant.banners.filter(b => b.active).forEach((_, i) => { %>
    <button class="banner-dot w-2 h-2 rounded-full bg-white/60 transition-all <%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>"></button>
    <% }) %>
  </div>
  <% } %>
</section>
<% } else { %>
<!-- بدون بنر: مساحة ترحيبية صغيرة -->
<section class="bg-gradient-to-l from-pink-50 to-white px-4 py-6">
  <h1 class="text-xl font-black text-gray-800"><%= storeName %></h1>
  <p class="text-sm text-gray-500 mt-1">تسوق الآن بأفضل الأسعار</p>
</section>
<% } %>

<!-- ─── المنتجات المميزة (Featured) ──────────────────────────────────────── -->
<% if (featured.length > 0) { %>
<section class="px-4 pt-6 pb-2">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-bold text-gray-800">✦ المميزة</h2>
    <a href="/products?featured=1" class="text-xs text-pink-500 font-medium">عرض الكل</a>
  </div>
  <div class="flex gap-3 overflow-x-auto scrollbar-hide pb-1">
    <% featured.forEach(p => { %>
    <a href="/products/<%= p.slug %>" class="flex-none w-32 group">
      <div class="relative aspect-square rounded-2xl overflow-hidden bg-gray-50 shadow-sm">
        <img src="<%= p.images[0] || '/img/placeholder.png' %>" alt="<%= p.name %>"
             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
             loading="lazy" onerror="this.src='/img/placeholder.png'" />
      </div>
      <p class="text-xs font-semibold text-gray-700 mt-1.5 line-clamp-1"><%= p.name %></p>
      <p class="text-xs text-gray-500"><%= p.basePrice.toLocaleString('ar-IQ') %> <%= currency || 'د.ع' %></p>
    </a>
    <% }) %>
  </div>
</section>
<% } %>

<!-- ─── أحدث المنتجات ──────────────────────────────────────────────────── -->
<section class="px-4 pt-5 pb-6">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-bold text-gray-800">جميع المنتجات</h2>
    <a href="/products" class="text-xs text-pink-500 font-medium flex items-center gap-1">
      عرض الكل <i class="fas fa-arrow-left text-xs"></i>
    </a>
  </div>

  <% if (recent.length > 0) { %>
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
    <% recent.forEach(p => { %>
    <%- include('partials/product-card', { product: p }) %>
    <% }) %>
  </div>
  <% } else { %>
  <div class="text-center py-16 text-gray-400">
    <i class="fas fa-box-open text-4xl mb-3 block"></i>
    <p class="text-sm">لا توجد منتجات بعد</p>
  </div>
  <% } %>

  <% if (recent.length >= 12) { %>
  <div class="text-center mt-6">
    <a href="/products" class="inline-block px-8 py-2.5 bg-pink-500 text-white text-sm font-semibold rounded-full hover:bg-pink-600 transition-colors">
      عرض المزيد
    </a>
  </div>
  <% } %>
</section>

<%- include('partials/footer') %>

<% if (featured.length > 0) { %>
<section class="relative overflow-hidden bg-gradient-to-b from-amber-50 to-white">
  <div class="relative max-w-7xl mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold text-amber-900">✦ النوادر والمميزة</h2>
      <a href="/products?tag=نوادر" class="text-sm text-amber-700 hover:underline">عرض الكل</a>
    </div>
    <div class="slider-wrapper relative">
      <div class="slider-track flex gap-4 overflow-x-auto pb-2 snap-x snap-mandatory scroll-smooth" id="featuredSlider">
        <% featured.forEach(p => { %>
        <a href="/products/<%= p.slug %>" class="snap-start flex-none w-44 md:w-52 group">
          <div class="relative rounded-2xl overflow-hidden bg-white shadow-md hover:shadow-xl transition-all duration-300">
            <div class="aspect-square overflow-hidden bg-gray-50">
              <img src="<%= p.images[0] || '/img/placeholder.png' %>" alt="<%= p.name %>"
                   class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                   loading="lazy" onerror="this.src='/img/placeholder.png'" />
            </div>
            <% if (p.tags && p.tags.includes('نوادر')) { %>
            <span class="absolute top-2 right-2 bg-amber-600 text-white text-xs px-2 py-0.5 rounded-full">نادر</span>
            <% } %>
          </div>
          <div class="mt-2 px-1">
            <p class="text-sm font-semibold text-gray-800 line-clamp-1 group-hover:text-amber-700 transition-colors"><%= p.name %></p>
            <p class="text-amber-700 font-bold text-sm mt-0.5"><%= p.basePrice.toLocaleString('ar-IQ') %> د.ع</p>
          </div>
        </a>
        <% }) %>
      </div>
      <!-- Arrows -->
      <button onclick="scrollSlider('featuredSlider',-1)" class="slider-btn-prev absolute right-0 top-1/2 -translate-y-1/2 -mr-4 bg-white shadow-lg rounded-full w-9 h-9 flex items-center justify-center hover:bg-amber-50 z-10 hidden md:flex">
        <i class="fas fa-chevron-right text-amber-700 text-sm"></i>
      </button>
      <button onclick="scrollSlider('featuredSlider', 1)" class="slider-btn-next absolute left-0 top-1/2 -translate-y-1/2 -ml-4 bg-white shadow-lg rounded-full w-9 h-9 flex items-center justify-center hover:bg-amber-50 z-10 hidden md:flex">
        <i class="fas fa-chevron-left text-amber-700 text-sm"></i>
      </button>
    </div>
  </div>
</section>
<% } %>

<!-- ─── Recently Added ─────────────────────────────────────────────── -->
<section class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-bold text-gray-800">أحدث المنتجات</h2>
    <a href="/products" class="text-sm text-amber-700 hover:underline flex items-center gap-1">
      عرض الكل <i class="fas fa-arrow-left text-xs"></i>
    </a>
  </div>

  <!-- Category Filter Tabs -->
  <% if (categories.length > 0) { %>
  <div class="flex gap-2 overflow-x-auto pb-3 mb-6 scrollbar-hide">
    <a href="/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium border border-amber-300 bg-amber-600 text-white whitespace-nowrap">الكل</a>
    <% categories.forEach(cat => { %>
    <a href="/products?cat=<%= cat._id %>" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 bg-white hover:bg-amber-50 hover:border-amber-300 whitespace-nowrap transition-all"><%= cat.name %></a>
    <% }) %>
  </div>
  <% } %>

  <!-- Products Grid -->
  <% if (recent.length > 0) { %>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
    <% recent.forEach(p => { %>
    <%- include('partials/product-card', { product: p }) %>
    <% }) %>
  </div>
  <% } else { %>
  <div class="text-center py-20 text-gray-400">
    <i class="fas fa-box-open text-5xl mb-4 block"></i>
    <p>لا توجد منتجات بعد</p>
  </div>
  <% } %>
</section>

<%- include('partials/footer') %>

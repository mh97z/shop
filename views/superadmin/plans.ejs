<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Platform Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-gray-50">
<nav class="bg-indigo-700 text-white px-6 py-3 flex items-center justify-between">
  <span class="font-bold text-lg">Platform Admin</span>
  <div class="flex gap-4 text-sm">
    <a href="/superadmin" class="hover:text-indigo-200">الرئيسية</a>
    <a href="/superadmin/tenants" class="hover:text-indigo-200">المتاجر</a>
    <a href="/superadmin/plans" class="font-bold">الباقات</a>
    <form method="POST" action="/superadmin/logout" class="inline"><button class="hover:text-red-300">خروج</button></form>
  </div>
</nav>
<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">الباقات</h1>
    <button onclick="document.getElementById('newPlanModal').classList.remove('hidden')"
            class="bg-indigo-600 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-indigo-700">
      <i class="fas fa-plus me-1"></i> باقة جديدة
    </button>
  </div>

  <!-- Plans Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <% plans.forEach(plan => { %>
    <div class="bg-white rounded-2xl p-5 shadow-sm border-2" style="border-color: <%= plan.popular ? plan.color : 'transparent' %>">
      <% if (plan.popular) { %>
      <span class="text-xs font-semibold px-2 py-0.5 rounded-full text-white mb-2 inline-block" style="background:<%= plan.color %>">الأكثر شعبية</span>
      <% } %>
      <h3 class="text-xl font-bold text-gray-800"><%= plan.nameAr %></h3>
      <p class="text-xs text-gray-400 mb-2"><%= plan.name %></p>
      <p class="text-3xl font-black" style="color:<%= plan.color %>">$<%= plan.price %><span class="text-sm font-normal text-gray-400">/شهر</span></p>
      <div class="mt-3 text-sm text-gray-500">
        <div class="flex items-center gap-2 mb-1">
          <i class="fas fa-box text-xs" style="color:<%= plan.color %>"></i>
          <%= plan.productLimit === -1 ? 'منتجات غير محدودة' : `حتى ${plan.productLimit} منتج` %>
        </div>
        <% if (plan.customDomain) { %>
        <div class="flex items-center gap-2 mb-1"><i class="fas fa-globe text-xs" style="color:<%= plan.color %>"></i> دومين مخصص</div>
        <% } %>
      </div>
      <ul class="mt-3 space-y-1">
        <% (plan.features || []).forEach(f => { %>
        <li class="text-sm text-gray-600 flex items-start gap-2">
          <i class="fas fa-check text-green-500 text-xs mt-1"></i> <%= f %>
        </li>
        <% }) %>
      </ul>
    </div>
    <% }) %>
  </div>
</div>

<!-- Modal: باقة جديدة -->
<div id="newPlanModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl w-full max-w-lg p-6 max-h-screen overflow-y-auto">
    <div class="flex justify-between items-center mb-5">
      <h2 class="text-lg font-bold">إضافة باقة</h2>
      <button onclick="document.getElementById('newPlanModal').classList.add('hidden')"><i class="fas fa-times text-gray-400"></i></button>
    </div>
    <form method="POST" action="/superadmin/plans" class="space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">الاسم (EN)</label>
          <input type="text" name="name" required placeholder="Basic" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">الاسم (AR)</label>
          <input type="text" name="nameAr" required placeholder="الأساسية" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">السعر الشهري ($)</label>
          <input type="number" name="price" required min="0" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">حد المنتجات (-1 = غير محدود)</label>
          <input type="number" name="productLimit" value="20" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">اللون</label>
          <input type="color" name="color" value="#6366f1" class="w-full h-10 border border-gray-200 rounded-xl px-2 cursor-pointer" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">الترتيب</label>
          <input type="number" name="sortOrder" value="0" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none" />
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">المزايا (كل سطر ميزة)</label>
        <textarea name="features" rows="4" class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none resize-none" placeholder="حتى 20 منتج&#10;دعم فني&#10;رفع صور"></textarea>
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" name="popular" id="popular" class="rounded" />
        <label for="popular" class="text-sm text-gray-600">الأكثر شعبية</label>
      </div>
      <button type="submit" class="w-full bg-indigo-600 text-white font-semibold py-2.5 rounded-xl hover:bg-indigo-700 transition-colors">حفظ الباقة</button>
    </form>
  </div>
</div>
</body>
</html>

# ─── قاعدة البيانات ─────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/saas_store

# ─── الجلسات ────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_secret_key

# ─── السيرفر ────────────────────────────────────────
PORT=1112
NODE_ENV=production

# ─── المنصة ─────────────────────────────────────────
PLATFORM_NAME=متجركم
PLATFORM_DOMAIN=yourdomain.com
DEFAULT_TENANT_SUBDOMAIN=demo

# ─── Super Admin (لوحة إدارة المنصة) ────────────────
SUPER_ADMIN_DOMAIN=admin.yourdomain.com
SUPER_ADMIN_USER=superadmin
SUPER_ADMIN_PASS=change_this_strong_password

# ─── ملاحظة ─────────────────────────────────────────
# المتغيرات التالية أصبحت per-tenant في قاعدة البيانات:
# STORE_NAME      → Tenant.storeName
# ADMIN_USERNAME  → Tenant.adminUsername
# ADMIN_PASSWORD  → Tenant.adminPassword
# WHATSAPP_NUMBER → Tenant.whatsapp
# INSTAGRAM_URL   → Tenant.instagram
# TIKTOK_URL      → Tenant.tiktok
# TELEGRAM_URL    → Tenant.telegram

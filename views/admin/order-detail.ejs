<%- include('partials/admin-header') %>

<div class="max-w-2xl">
  <a href="/admin/orders" class="text-sm text-gray-400 hover:text-amber-600 flex items-center gap-1 mb-5">
    <i class="fas fa-arrow-right text-xs"></i> العودة للطلبات
  </a>

  <div class="bg-white rounded-2xl shadow-sm p-6 space-y-6">
    <!-- Header -->
    <div class="flex items-start justify-between">
      <div>
        <h2 class="text-xl font-bold text-gray-800"><%= order.orderNumber %></h2>
        <p class="text-sm text-gray-400 mt-0.5"><%= new Date(order.createdAt).toLocaleString('ar-IQ') %></p>
      </div>
      <span class="px-3 py-1 rounded-full text-sm font-medium
        <%= order.status === 'pending' ? 'bg-yellow-100 text-yellow-700' :
            order.status === 'confirmed' ? 'bg-blue-100 text-blue-700' :
            order.status === 'shipped' ? 'bg-purple-100 text-purple-700' :
            order.status === 'delivered' ? 'bg-green-100 text-green-700' :
            'bg-red-100 text-red-700' %>">
        <%= order.status === 'pending' ? 'معلق' :
            order.status === 'confirmed' ? 'مؤكد' :
            order.status === 'shipped' ? 'تم الشحن' :
            order.status === 'delivered' ? 'مسلّم' : 'ملغي' %>
      </span>
    </div>

    <!-- Customer Info -->
    <div class="bg-gray-50 rounded-xl p-4">
      <h3 class="font-semibold text-gray-700 text-sm mb-3">بيانات العميل</h3>
      <div class="grid grid-cols-2 gap-3 text-sm">
        <div><span class="text-gray-400">الاسم:</span> <span class="font-medium"><%= order.customer.name %></span></div>
        <div><span class="text-gray-400">الهاتف:</span> <span class="font-medium" dir="ltr"><%= order.customer.phone %></span></div>
        <div class="col-span-2"><span class="text-gray-400">العنوان:</span> <span class="font-medium"><%= order.customer.address %></span></div>
        <% if (order.customer.notes) { %>
        <div class="col-span-2"><span class="text-gray-400">ملاحظات:</span> <span><%= order.customer.notes %></span></div>
        <% } %>
      </div>
    </div>

    <!-- Items -->
    <div>
      <h3 class="font-semibold text-gray-700 text-sm mb-3">المنتجات</h3>
      <div class="divide-y divide-gray-50 border rounded-xl overflow-hidden">
        <% order.items.forEach(item => { %>
        <div class="flex gap-3 items-center p-3">
          <img src="<%= item.image || '/img/placeholder.png' %>" alt="" class="w-12 h-12 rounded-lg object-cover bg-gray-50" onerror="this.src='/img/placeholder.png'" />
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-800 line-clamp-1"><%= item.name %></p>
            <p class="text-xs text-gray-400">الحجم: <%= item.size %> | الكمية: <%= item.qty %></p>
          </div>
          <p class="font-semibold text-gray-800 text-sm"><%= (item.price * item.qty).toLocaleString('ar-IQ') %> د.ع</p>
        </div>
        <% }) %>
      </div>
      <div class="flex justify-between font-bold text-lg mt-3 px-1">
        <span>المجموع الكلي</span>
        <span class="text-amber-700"><%= order.total.toLocaleString('ar-IQ') %> د.ع</span>
      </div>
    </div>

    <!-- Update Status -->
    <div class="border-t pt-5">
      <form method="POST" action="/admin/orders/<%= order._id %>/status?_method=PUT" class="flex gap-3">
        <select name="status" class="flex-1 border border-gray-200 rounded-xl px-4 py-2 text-sm focus:outline-none focus:border-amber-400 bg-white">
          <option value="pending"   <%= order.status === 'pending'   ? 'selected' : '' %>>معلق</option>
          <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>مؤكد</option>
          <option value="shipped"   <%= order.status === 'shipped'   ? 'selected' : '' %>>تم الشحن</option>
          <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>مسلّم</option>
          <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>ملغي</option>
        </select>
        <button type="submit" class="bg-amber-600 text-white px-5 py-2 rounded-xl text-sm font-semibold hover:bg-amber-700 transition-colors">
          تحديث الحالة
        </button>
      </form>
    </div>
  </div>
</div>

<%- include('partials/admin-footer') %>

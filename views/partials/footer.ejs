<%
  const safeTenant = typeof tenant !== 'undefined' ? tenant : null;
  const safeStoreName = typeof storeName !== 'undefined' ? storeName : 'Platform';
  const safeInstagram = typeof instagram !== 'undefined' ? instagram : '#';
  const safeTiktok = typeof tiktok !== 'undefined' ? tiktok : '#';
  const safeFacebook = typeof facebook !== 'undefined' ? facebook : '#';
  const safeWhatsapp = typeof whatsapp !== 'undefined' ? whatsapp : '';
  const safePoweredByVisible = typeof poweredByVisible !== 'undefined' ? poweredByVisible : true;
%>
</main>

<!-- ─── WhatsApp Float Button ───────────────────────────────────────────── -->
<% if (safeWhatsapp) { %>
<a href="https://wa.me/<%= safeWhatsapp %>" target="_blank" rel="noopener"
   class="fixed bottom-6 left-4 z-40 w-14 h-14 bg-green-500 rounded-full flex items-center justify-center shadow-lg hover:bg-green-600 transition-colors">
  <i class="fab fa-whatsapp text-white text-2xl"></i>
</a>
<% } %>

<!-- ─── Footer ──────────────────────────────────────────────────────────── -->
<footer class="bg-white border-t border-gray-100 mt-8">
  <div class="px-4 py-8 text-center">
    <!-- Logo & Name -->
    <div class="flex flex-col items-center mb-4">
      <% if (safeTenant && safeTenant.logo) { %>
      <img src="<%= safeTenant.logo %>" alt="<%= safeStoreName %>" class="h-12 w-12 object-contain rounded-full mb-2" loading="lazy" />
      <% } %>
      <span class="font-bold text-lg text-gray-800"><%= safeStoreName %></span>
    </div>

    <!-- Social Icons -->
    <div class="flex justify-center gap-5 mb-4">
      <% if (safeTiktok && safeTiktok !== '#') { %>
      <a href="<%= safeTiktok %>" target="_blank" rel="noopener" class="text-gray-500 hover:text-gray-800 transition-colors">
        <i class="fab fa-tiktok text-2xl"></i>
      </a>
      <% } %>
      <% if (safeInstagram && safeInstagram !== '#') { %>
      <a href="<%= safeInstagram %>" target="_blank" rel="noopener" class="text-gray-500 hover:text-pink-500 transition-colors">
        <i class="fab fa-instagram text-2xl"></i>
      </a>
      <% } %>
      <% if (safeFacebook && safeFacebook !== '#') { %>
      <a href="<%= safeFacebook %>" target="_blank" rel="noopener" class="text-gray-500 hover:text-blue-600 transition-colors">
        <i class="fab fa-facebook text-2xl"></i>
      </a>
      <% } %>
    </div>

    <% if (safePoweredByVisible) { %>
    <p class="text-xs text-gray-400">Powered by <%= process.env.PLATFORM_NAME || 'Platform' %></p>
    <% } %>
  </div>
</footer>

<!-- ─── Toast Notification ──────────────────────────────────────────────── -->
<div id="toast" class="hidden fixed top-20 left-1/2 -translate-x-1/2 z-50 bg-gray-900 text-white text-sm px-5 py-3 rounded-full shadow-lg transition-all"></div>

<!-- ─── Scripts ─────────────────────────────────────────────────────────── -->
<script src="/js/main.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Platform Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-gray-50">
<!-- Header -->
<nav class="bg-indigo-700 text-white px-6 py-3 flex items-center justify-between">
  <div class="flex items-center gap-3">
    <i class="fas fa-shield-alt text-xl"></i>
    <span class="font-bold text-lg">Platform Admin</span>
  </div>
  <div class="flex items-center gap-4 text-sm">
    <a href="/superadmin" class="hover:text-indigo-200">الرئيسية</a>
    <a href="/superadmin/tenants" class="hover:text-indigo-200">المتاجر</a>
    <a href="/superadmin/plans" class="hover:text-indigo-200">الباقات</a>
    <form method="POST" action="/superadmin/logout" class="inline">
      <button class="hover:text-red-300">تسجيل الخروج</button>
    </form>
  </div>
</nav>

<div class="max-w-6xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">لوحة التحكم</h1>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-2xl p-5 shadow-sm text-center">
      <div class="text-3xl font-bold text-indigo-600"><%= tenantCount %></div>
      <div class="text-sm text-gray-500 mt-1">إجمالي المتاجر</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm text-center">
      <div class="text-3xl font-bold text-green-600"><%= activeTenants %></div>
      <div class="text-sm text-gray-500 mt-1">متاجر نشطة</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm text-center">
      <div class="text-3xl font-bold text-orange-500"><%= plans.length %></div>
      <div class="text-sm text-gray-500 mt-1">الباقات</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm text-center">
      <div class="text-3xl font-bold text-pink-500"><%= tenantCount - activeTenants %></div>
      <div class="text-sm text-gray-500 mt-1">غير نشطة</div>
    </div>
  </div>

  <!-- Pricing Plans -->
  <h2 class="text-lg font-bold text-gray-800 mb-4">الباقات المتاحة</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <% plans.forEach(plan => { %>
    <div class="bg-white rounded-2xl p-5 shadow-sm border-2 <%= plan.popular ? 'border-indigo-500' : 'border-transparent' %>">
      <% if (plan.popular) { %><span class="text-xs bg-indigo-600 text-white px-2 py-0.5 rounded-full font-medium mb-2 inline-block">الأكثر شعبية</span><% } %>
      <h3 class="text-lg font-bold text-gray-800"><%= plan.nameAr %></h3>
      <p class="text-2xl font-black mt-1" style="color: <%= plan.color %>">$<%= plan.price %><span class="text-sm font-normal text-gray-400">/شهر</span></p>
      <ul class="mt-3 space-y-1">
        <% (plan.features || []).forEach(f => { %>
        <li class="text-sm text-gray-600 flex items-center gap-2">
          <i class="fas fa-check text-green-500 text-xs"></i> <%= f %>
        </li>
        <% }) %>
      </ul>
    </div>
    <% }) %>
  </div>

  <!-- Recent Tenants -->
  <h2 class="text-lg font-bold text-gray-800 mb-4">آخر المتاجر</h2>
  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
        <tr>
          <th class="px-4 py-3 text-right">المتجر</th>
          <th class="px-4 py-3 text-right">المالك</th>
          <th class="px-4 py-3 text-right">الباقة</th>
          <th class="px-4 py-3 text-right">الحالة</th>
          <th class="px-4 py-3 text-right">تاريخ الإنشاء</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% recentTenants.forEach(t => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-semibold text-gray-800"><%= t.storeName %><br><span class="text-xs font-normal text-gray-400"><%= t.subdomain %></span></td>
          <td class="px-4 py-3 text-gray-600"><%= t.ownerName %></td>
          <td class="px-4 py-3"><span class="text-xs px-2 py-0.5 rounded-full bg-indigo-100 text-indigo-700"><%= t.plan?.nameAr || 'بدون باقة' %></span></td>
          <td class="px-4 py-3"><span class="text-xs px-2 py-0.5 rounded-full <%= t.active ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600' %>"><%= t.active ? 'نشط' : 'موقوف' %></span></td>
          <td class="px-4 py-3 text-gray-400"><%= new Date(t.createdAt).toLocaleDateString('ar') %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
</body>
</html>

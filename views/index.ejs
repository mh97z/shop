<%- include('partials/header') %>

<!-- ─── Hero Banner / Slider ─────────────────────────────────────────────── -->
<% if (tenant && tenant.banners && tenant.banners.filter(b => b.active).length > 0) { %>
<section class="relative overflow-hidden" id="bannerSection">
  <div class="banner-slider" id="bannerSlider">
    <% tenant.banners.filter(b => b.active).forEach((banner, i) => { %>
    <div class="banner-slide <%= i === 0 ? 'active' : '' %>">
      <% if (banner.link) { %><a href="<%= banner.link %>"><% } %>
      <img src="<%= banner.image %>" alt="<%= banner.title || storeName %>"
           class="w-full h-48 sm:h-64 object-cover"
           loading="<%= i === 0 ? 'eager' : 'lazy' %>" />
      <% if (banner.title) { %>
      <div class="banner-overlay">
        <h2 class="text-xl font-black leading-tight"><%= banner.title %></h2>
        <% if (banner.subtitle) { %><p class="text-sm mt-1 opacity-90"><%= banner.subtitle %></p><% } %>
      </div>
      <% } %>
      <% if (banner.link) { %></a><% } %>
    </div>
    <% }) %>
  </div>
  <% if (tenant.banners.filter(b => b.active).length > 1) { %>
  <!-- Dots -->
  <div class="flex justify-center gap-1.5 py-2 absolute bottom-2 w-full">
    <% tenant.banners.filter(b => b.active).forEach((_, i) => { %>
    <button class="banner-dot w-2 h-2 rounded-full bg-white/60 transition-all <%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>"></button>
    <% }) %>
  </div>
  <% } %>
</section>
<% } else { %>
<!-- بدون بنر: مساحة ترحيبية صغيرة -->
<section class="bg-gradient-to-l from-pink-50 to-white px-4 py-6">
  <h1 class="text-xl font-black text-gray-800"><%= storeName %></h1>
  <p class="text-sm text-gray-500 mt-1">تسوق الآن بأفضل الأسعار</p>
</section>
<% } %>

<!-- ─── المنتجات المميزة (Featured) ──────────────────────────────────────── -->
<% if (featured.length > 0) { %>
<section class="px-4 pt-6 pb-2">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-bold text-gray-800">✦ المميزة</h2>
    <a href="/products?featured=1" class="text-xs text-pink-500 font-medium">عرض الكل</a>
  </div>
  <div class="flex gap-3 overflow-x-auto scrollbar-hide pb-1">
    <% featured.forEach(p => { %>
    <a href="/products/<%= p.slug %>" class="flex-none w-32 group">
      <div class="relative aspect-square rounded-2xl overflow-hidden bg-gray-50 shadow-sm">
        <img src="<%= p.images[0] || '/img/placeholder.png' %>" alt="<%= p.name %>"
             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
             loading="lazy" onerror="this.src='/img/placeholder.png'" />
      </div>
      <p class="text-xs font-semibold text-gray-700 mt-1.5 line-clamp-1"><%= p.name %></p>
      <p class="text-xs text-gray-500"><%= p.basePrice.toLocaleString('ar-IQ') %> <%= currency || 'د.ع' %></p>
    </a>
    <% }) %>
  </div>
</section>
<% } %>

<!-- ─── أحدث المنتجات ──────────────────────────────────────────────────── -->
<section class="px-4 pt-5 pb-6">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-bold text-gray-800">جميع المنتجات</h2>
    <a href="/products" class="text-xs text-pink-500 font-medium flex items-center gap-1">
      عرض الكل <i class="fas fa-arrow-left text-xs"></i>
    </a>
  </div>

  <% if (recent.length > 0) { %>
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
    <% recent.forEach(p => { %>
    <%- include('partials/product-card', { product: p }) %>
    <% }) %>
  </div>
  <% } else { %>
  <div class="text-center py-16 text-gray-400">
    <i class="fas fa-box-open text-4xl mb-3 block"></i>
    <p class="text-sm">لا توجد منتجات بعد</p>
  </div>
  <% } %>

  <% if (recent.length >= 12) { %>
  <div class="text-center mt-6">
    <a href="/products" class="inline-block px-8 py-2.5 bg-pink-500 text-white text-sm font-semibold rounded-full hover:bg-pink-600 transition-colors">
      عرض المزيد
    </a>
  </div>
  <% } %>
</section>

<%- include('partials/footer') %>
